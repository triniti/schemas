<?xml version="1.0" encoding="UTF-8" ?>
<pbj-schema xmlns="http://gdbots.io/pbj/xsd"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://gdbots.io/pbj/xsd http://gdbots.io/pbj/xsd/schema.xsd">

  <schema id="pbj:triniti:curator:mixin:live-bloggable:1-0-0" mixin="true"
      extends="gdbots:ncr:mixin:node:v1">
    <fields>
      <field name="is_live_blog" type="boolean">
        <description>
          When true, this node represents a live blog parent; individual updates
          are typically authored as teasers referencing this node.
        </description>
      </field>
    </fields>
  </schema>
</pbj-schema>
